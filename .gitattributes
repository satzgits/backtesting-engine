# Auto-detect text files and normalize to LF
* text=auto

# Python
*.py text diff=python
*.pyc binary

# C++
*.cpp text diff=cpp
*.hpp text diff=cpp

# Docs
*.md text
*.txt text
*.yml text
*.yaml text
*.toml text
*.json text

# Binaries
*.png binary
*.jpg binary
*.pt binary
*.pth binary
*.onnx binary
